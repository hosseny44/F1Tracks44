<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:background="@drawable/race_item_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- العلم واسم الدولة + أيقونة المفضلة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivCountry"
            android:layout_width="54dp"
            android:layout_height="39dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Country Flag" />

        <TextView
            android:id="@+id/tvCountryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Country Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <ImageButton
            android:id="@+id/ivFavorite"
            android:layout_width="24dp"
            android:layout_height="16dp"
            android:background="@android:color/transparent"
            android:src="@drawable/star_24"
            android:padding="6dp"/>

    </LinearLayout>

    <!-- المعلومات + صورة التراك -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <!-- المعلومات النصية -->
        <TextView
            android:id="@+id/tvEXP"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EXP info here"
            android:textSize="16sp"
            android:textColor="#050505" />

        <!-- صورة التراك -->
        <ImageView
            android:id="@+id/ivStadiumImage"
            android:layout_width="150dp"
            android:layout_height="100dp"
            android:layout_marginStart="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="Track Image" />
    </LinearLayout>

</LinearLayout>