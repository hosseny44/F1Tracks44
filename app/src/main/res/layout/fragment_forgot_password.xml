<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Fragments.ForgotPasswordFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <EditText
            android:id="@+id/etEmailForfgotpassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="82dp"
            android:ems="10"
            android:hint="enter email to reset..."
            android:inputType="text"
            android:minHeight="48dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnResetForgotPassword"
            android:layout_width="100dp"
            android:layout_height="49dp"
            android:layout_marginStart="48dp"
            android:layout_marginTop="47dp"
            android:layout_marginBottom="502dp"
            android:backgroundTint="#132440"
            android:text="RESET"
            android:textColor="#000000"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.017"
            app:layout_constraintStart_toStartOf="@+id/etEmailForfgotpassword"
            app:layout_constraintTop_toBottomOf="@+id/etEmailForfgotpassword"
            app:layout_constraintVertical_bias="1.0" />

        <Button
            android:id="@+id/btngohome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#132440"
            android:text="Go Home"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/btnResetForgotPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>