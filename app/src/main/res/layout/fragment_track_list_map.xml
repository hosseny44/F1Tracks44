<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutTrackListMap"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".TrackListMap">

    <!-- Header مع صورة المستخدم و SearchView -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <!-- SearchView -->
        <SearchView
            android:id="@+id/srchViewTrackListMapFragment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:queryHint="Search Tracks..."
            android:iconifiedByDefault="false" />

        <ImageView
            android:id="@+id/ivProfileTrackListMapFragment"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_profile"
       />

    </LinearLayout>

    <!-- RecyclerView لعرض التراكات -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTracklistMap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>